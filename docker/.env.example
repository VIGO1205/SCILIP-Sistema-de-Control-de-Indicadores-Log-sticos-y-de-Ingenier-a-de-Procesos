# ──────────────────────────────────────────────────────────────────────
# Variables de entorno para Docker (Producción)
# Copiar este archivo a .env en la misma carpeta docker/ y completar:
#   cp docker/.env.example docker/.env
# ──────────────────────────────────────────────────────────────────────

# ─── Base de Datos PostgreSQL ─────────────────────────────────────────
DB_USER=usuario
DB_PASSWORD=password
DB_NAME=proyectocd

# ─── Seguridad ────────────────────────────────────────────────────────
# IMPORTANTE: Cambiar por una cadena aleatoria larga en producción real
JWT_SECRET=cambia-esto-en-produccion-con-un-secreto-largo-y-aleatorio

# ─── Inteligencia Artificial (Groq) ──────────────────────────────────
# Obtén tu API Key gratis en: https://console.groq.com/keys
# Sin esta key, el botón ✨ de interpretación IA no mostrará texto
GROQ_API_KEY=tu_api_key_de_groq_aqui
