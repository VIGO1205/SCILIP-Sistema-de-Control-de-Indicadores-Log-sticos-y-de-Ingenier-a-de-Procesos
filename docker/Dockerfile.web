FROM node:20-alpine AS builder

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@9.0.0

# Copy workspace files
COPY pnpm-lock.yaml ./
COPY pnpm-workspace.yaml ./
COPY package.json ./

# Copy packages and apps
COPY frontend/ ./frontend/
COPY shared/ ./shared/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Build the web app
RUN pnpm --filter web build

FROM node:20-alpine AS runner

WORKDIR /app

# Copy built files
COPY --from=builder /app/frontend/web/.next ./.next
COPY --from=builder /app/frontend/web/public ./public
COPY --from=builder /app/frontend/web/package.json ./package.json
COPY --from=builder /app/frontend/web/next.config.js ./next.config.js
COPY --from=builder /app/node_modules ./node_modules

# Set environment variables
ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

# Start the server
CMD ["pnpm", "--filter", "web", "start"]
