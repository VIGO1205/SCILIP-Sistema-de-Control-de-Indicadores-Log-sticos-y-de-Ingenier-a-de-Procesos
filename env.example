# Copiar a backend/database/.env, backend/api/.env y frontend/web/.env (misma DATABASE_URL).
DATABASE_URL="postgresql://usuario:password@localhost:5433/proyectocd?schema=public"

# API Nest (apps/api)
PORT=4000
JWT_SECRET=cambia-esto-en-produccion

# Redis opcional (colas Bull); si no tienes Redis, comenta BullModule en app.module o usa valores por defecto
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend (apps/web) — URL del API para tRPC en el navegador
NEXT_PUBLIC_API_URL=http://localhost:4000

# Inteligencia Artificial (API Key de Groq para LLMs)
# Regístrate gratis en https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_de_groq_aqui
